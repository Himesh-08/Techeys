# CrimsonStack Backend Configuration Template
# Copy this file to '.env' and fill in your SMTP credentials to receive inquiries in your inbox.

PORT=8000

# 1. SMTP Provider Settings (Gmail, Outlook, Custom Office SMTP)
# For Gmail, use 'smtp.gmail.com'. For Outlook/Office365, use 'smtp.office365.com'.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# 2. Authentication Credentials
# This is the sender email account.
# Note: For Gmail/Outlook, you must generate an "App Password" rather than your login password.
SMTP_USER=office@yourdomain.com
SMTP_PASS=abcd-efgh-ijkl-mnop

# 3. Notification Recipient
# The office email address where you want to receive the client project inquiries.
# If left blank, it defaults to the SMTP_USER address above.
EMAIL_TO=himeshmungapati08@gmail.com
